// --- BOOL CASTING ---

func boolToInt(value: Bool) -> Int {
    if value {
        return 1
    } else {
        return 0
    }
}

func boolToFloat(value: Bool) -> Float {
    if value {
        return 1.0
    } else {
        return 0.0
    }
}

// --- FLOAT CASTING ---

func floatToInt(value: Float) -> Int {
    return Builtin.ftoi(value)
}

// --- INT CASTING ---

func intToFloat(value: Int) -> Float {
    return Builtin.itof(value)
}
